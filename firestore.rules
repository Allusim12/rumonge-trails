
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow create: if isOwner(adminId); 
      allow list, update, delete: if isAdmin();
    }

    match /trendingUpdates/{updateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']);
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /wonderAttractions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /culturalHeritages/{id} { allow read: if true; allow write: if isAdmin(); }
    match /events/{id} { allow read: if true; allow write: if isAdmin(); }
    match /accommodations/{id} { allow read: if true; allow write: if isAdmin(); }
    match /localCuisineSpots/{id} { allow read: if true; allow write: if isAdmin(); }
    match /transportationOptions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_content/{id} { allow read: if true; allow write: if isAdmin(); }
    match /mediaAssets/{id} { allow read: if true; allow write: if isAdmin(); }
    match /newsletter_subscriptions/{id} { allow create: if true; allow read, write: if isAdmin(); }
    match /travelTips/{id} { allow read: if true; allow write: if isAdmin(); }
    
    match /bookingRequests/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /site_inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /reviews/{id} { 
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /users/{userId}/itineraries/{id} { allow read, write: if isOwner(userId); }
    match /users/{userId}/savedItems/{id} { allow read, write: if isOwner(userId); }
  }
}
