
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredInterests": { "type": "array", "items": { "type": "string" } },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "registeredAt"]
    },
    "TrendingUpdate": {
      "title": "TrendingUpdate",
      "type": "object",
      "description": "News updates and trending stories in Rumonge Commune.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string", "enum": ["Event", "Development", "Culture", "Tourism"] },
        "likedBy": { "type": "array", "items": { "type": "string" }, "description": "Array of user UIDs who liked this post." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "category", "createdAt"]
    },
    "NewsComment": {
      "title": "NewsComment",
      "type": "object",
      "description": "User comments on trending updates.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "text", "createdAt"]
    },
    "WonderAttraction": {
      "title": "WonderAttraction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "address": { "type": "string" },
        "rating": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "BookingRequest": {
      "title": "BookingRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "hotelId": { "type": "string" },
        "hotelName": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Contacted", "Closed"] },
        "requestedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MediaAsset": {
      "title": "MediaAsset",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["nature", "culture", "leisure", "food"] },
        "uploadedAt": { "type": "string" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/roles_admin/{adminId}": {
      "schema": "UserProfile",
      "description": "Admin roles."
    },
    "/trendingUpdates/{updateId}": {
      "schema": "TrendingUpdate",
      "description": "Global news and trending updates."
    },
    "/trendingUpdates/{updateId}/comments/{commentId}": {
      "schema": "NewsComment",
      "description": "Comments on news updates."
    },
    "/wonderAttractions/{wonderAttractionId}": { "schema": "WonderAttraction", "description": "Attractions." },
    "/bookingRequests/{requestId}": { "schema": "BookingRequest", "description": "Visitor booking interests." },
    "/mediaAssets/{assetId}": { "schema": "MediaAsset", "description": "Gallery images." },
    "/site_inquiries/{inquiryId}": { "schema": "Inquiry", "description": "General office inquiries." }
  }
}
